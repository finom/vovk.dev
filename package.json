{
  "name": "vovk.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run lint && tsc --noEmit && tsx --test scripts/generateContext/contextTransforms.test.ts",
    "predev": "npm run update-mdx-github-codeblocks",
    "predeploy": "npm run update-mdx-github-codeblocks",
    "dev": "vovk dev --next-dev",
    "dev-exit": "vovk dev --next-dev --exit",
    "build": "next build",
    "prebuild": "vovk generate && tsx ./scripts/generateContext/index.ts",
    "start": "next start",
    "lint": "biome check",
    "deploy": "rm -rf dist && deploy-to-git && git push",
    "upgrade": "npx npm-check-updates -u && npm install --legacy-peer-deps",
    "output-cli": "FORCE_COLOR=1 npx vovk-cli init@draft --channel=draft | npx ansi-to-html > output.html",
    "generate": "vovk generate",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "update-mdx-github-codeblocks": "tsx ./scripts/updateMDXFilesWithGithubContent.ts"
  },
  "config": {
    "deployToGit": {
      "repository": "git@github.com:finom/vovk.dev.git",
      "branch": "gh-pages",
      "folder": "dist",
      "script": "npm run build && find dist -mindepth 1 -not -path 'dist/.git*' -delete && cp -a out/. dist/",
      "commit": "Automatic commit text",
      "user": {
        "email": "andrii@gubanov.eu",
        "name": "Andrey Gubanov"
      }
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@scalar/api-reference-react": "^0.9.9",
    "@types/json-schema": "^7.0.15",
    "asciinema-player": "^3.15.1",
    "bright": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "react-transition-group": "^4.4.5",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vovk": "^3.0.0",
    "vovk-ajv": "^0.0.2",
    "vovk-client": "^1.0.0",
    "vovk-examples": "^3.0.22",
    "vovk-react-query": "^0.0.1-draft.95",
    "zod": "^4.3.6"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "printWidth": 120
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-transition-group": "^4.4.12",
    "deploy-to-git": "^0.4.1",
    "pagefind": "^1.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "user-agent-data-types": "^0.4.2",
    "vovk-cli": "^0.0.1"
  }
}
